# Names match what Vercel's Neon integration auto-generates in production — no renaming
# needed there. Locally, point both at the same Docker Postgres connection string.
POSTGRES_PRISMA_URL="postgresql://user:password@localhost:5432/football_manager?schema=public"
DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5432/football_manager?schema=public"

AUTH_SECRET="generate-with-npx-auth-secret"
NEXTAUTH_URL="http://localhost:3000"

SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me"
